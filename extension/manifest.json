{
  "manifest_version": 3,
  "name": "OfferAIO — Auto Apply",
  "version": "1.0.0",
  "description": "Auto-fills Summer 2027 internship applications across the major job platforms — in your own browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "OfferAIO"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://*.workable.com/*",
    "https://*.jobvite.com/*",
    "https://*.bamboohr.com/*",
    "https://*.breezy.hr/*",
    "https://*.taleo.net/*",
    "https://*.joinhandshake.com/*",
    "https://www.linkedin.com/jobs/*",
    "https://*.ziprecruiter.com/*",
    "https://*.indeed.com/*",
    "https://wellfound.com/*",
    "https://tobyberg43.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.workable.com/*",
        "https://*.jobvite.com/*",
        "https://*.bamboohr.com/*",
        "https://*.breezy.hr/*",
        "https://*.taleo.net/*",
        "https://*.joinhandshake.com/*",
        "https://www.linkedin.com/jobs/*",
        "https://*.ziprecruiter.com/*",
        "https://*.indeed.com/*",
        "https://wellfound.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://tobyberg43.github.io/OfferAIO/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
