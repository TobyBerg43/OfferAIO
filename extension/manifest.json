{
  "manifest_version": 3,
  "name": "OfferAIO — Auto Apply",
  "version": "1.0.0",
  "description": "Auto-fills Summer 2027 internship applications across the major job platforms — in your own browser. You review and submit.",
  "homepage_url": "https://offeraio.com",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OfferAIO",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://*.workable.com/*",
    "https://*.jobvite.com/*",
    "https://*.bamboohr.com/*",
    "https://*.breezy.hr/*",
    "https://*.taleo.net/*",
    "https://*.joinhandshake.com/*",
    "https://www.linkedin.com/jobs/*",
    "https://*.ziprecruiter.com/*",
    "https://*.indeed.com/*",
    "https://wellfound.com/*",
    "https://offeraio.com/*",
    "https://tobyberg43.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.workable.com/*",
        "https://*.jobvite.com/*",
        "https://*.bamboohr.com/*",
        "https://*.breezy.hr/*",
        "https://*.taleo.net/*",
        "https://*.joinhandshake.com/*",
        "https://www.linkedin.com/jobs/*",
        "https://*.ziprecruiter.com/*",
        "https://*.indeed.com/*",
        "https://wellfound.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://offeraio.com/*",
        "https://tobyberg43.github.io/OfferAIO/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
